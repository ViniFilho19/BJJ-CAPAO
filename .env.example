# ============================================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA suba o .env para o GitHub
# ============================================================

# Banco de dados (Railway gera automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/bjj_db

# Mercado Pago — obtenha em https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-abcdef1234567890abcdef1234567890-000000000
MP_WEBHOOK_SECRET=sua_chave_secreta_do_webhook

# URL da sua aplicação (Railway fornece após deploy)
APP_BASE_URL=https://seu-projeto.up.railway.app

# E-mail de notificação interna (para você receber aviso de cada inscrição)
ADMIN_EMAIL=seuemail@gmail.com

# Chave secreta do Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=troque_isso_por_uma_chave_aleatoria_longa

# Ambiente: development | production
FLASK_ENV=production
